{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cppbuild",
			"label": "C/C++: cl.exe Build Active File",
			"command": "cl.exe",
			"args": ["/Zi", "/EHsc", "/nologo", "/Fe${fileDirname}\\${fileBasenameNoExtension}.exe", "${file}"],
			"options": {
				"cwd": "${fileDirname}"
			},
			"problemMatcher": ["$msCompile"],
			"group": "build",
			"detail": "Task generated by debugger"
		},
		{
			"label": "Build Godot (Debug - Standard)",
			"type": "shell",
			"command": "python",
			"args": [
				"-m",
				"SCons",
				"platform=windows",
				"target=template_debug",
				"dev_mode=yes",
				"debug_symbols=yes",
				"scu_build=yes",
				"cache_path=.scons_cache",
				"-j8"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": {
				"kind": "build",
				"isDefault": false
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Build Godot (Debug - Mono)",
			"type": "shell",
			"command": "python",
			"args": [
				"-m",
				"SCons",
				"platform=windows",
				"target=template_debug",
				"module_mono_enabled=yes",
				"dev_mode=yes",
				"debug_symbols=yes",
				"scu_build=yes",
				"cache_path=.scons_cache",
				"-j8"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": {
				"kind": "build",
				"isDefault": false
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Build Godot (Editor - Standard)",
			"type": "shell",
			"command": "python",
			"args": [
				"-m",
				"SCons",
				"platform=windows",
				"target=editor",
				"dev_mode=yes",
				"debug_symbols=yes",
				"scu_build=yes",
				"cache_path=.scons_cache",
				"-j8"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"problemMatcher": [],
			"detail": "Build standard editor (with debug symbols)"
		},
		{
			"label": "Build Godot (Editor - Mono)",
			"type": "shell",
			"command": "python",
			"args": [
				"-m",
				"SCons",
				"platform=windows",
				"target=editor",
				"module_mono_enabled=yes",
				"dev_mode=yes",
				"debug_symbols=yes",
				"scu_build=yes",
				"cache_path=.scons_cache",
				"-j8"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": {
				"kind": "build",
				"isDefault": false
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"problemMatcher": [],
			"detail": "Build Mono editor (with debug symbols)"
		},
		{
			"label": "Run Godot Editor (Quick Run, No Build)",
			"type": "shell",
			"command": "${workspaceFolder}/bin/godot.windows.editor.x86_64.exe",
			"args": ["--editor"],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"problemMatcher": [],
			"detail": "Run editor directly (skip compilation)"
		},
		{
			"label": "Run Godot Editor with Project (Quick Run, No Build)",
			"type": "shell",
			"command": "${workspaceFolder}/bin/godot.windows.editor.x86_64.exe",
			"args": ["--path", "${input:projectPath}", "--editor"],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"problemMatcher": [],
			"detail": "Open specified project (skip compilation)"
		},
		{
			"label": "Generate Mono Glue",
			"type": "shell",
			"command": "${workspaceFolder}/bin/godot.windows.editor.x86_64.mono.exe",
			"args": ["--headless", "--generate-mono-glue", "modules/mono/glue"],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"problemMatcher": [],
			"dependsOn": "Build Godot (Editor - Mono)"
		},
		{
			"label": "Build GodotSharp (.NET Assemblies)",
			"type": "shell",
			"command": "python",
			"args": [
				"modules/mono/build_scripts/build_assemblies.py",
				"--godot-output-dir=./bin",
				"--godot-platform=windows"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"problemMatcher": [],
			"dependsOn": "Generate Mono Glue"
		},
		{
			"label": "Full Build (Mono)",
			"type": "shell",
			"command": "echo",
			"args": ["Full build completed!"],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"problemMatcher": [],
			"dependsOn": "Build GodotSharp (.NET Assemblies)"
		},
		{
			"label": "Clean Build",
			"type": "shell",
			"command": "python",
			"args": ["-m", "SCons", "--clean"],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"problemMatcher": []
		}
	]
}
